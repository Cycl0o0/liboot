{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 19, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_LIBDIR": "lib"
      }
    },
    {
      "name": "release",
      "displayName": "Release (shared)",
      "description": "Optimized shared library; mirrors the CI cmake job.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "release-static",
      "displayName": "Release (static)",
      "inherits": "release",
      "cacheVariables": { "BUILD_SHARED_LIBS": "OFF" }
    },
    {
      "name": "debug",
      "displayName": "Debug (shared)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "debug-static",
      "displayName": "Debug (static)",
      "inherits": "debug",
      "cacheVariables": { "BUILD_SHARED_LIBS": "OFF" }
    }
  ],
  "buildPresets": [
    { "name": "release", "configurePreset": "release" },
    { "name": "release-static", "configurePreset": "release-static" },
    { "name": "debug", "configurePreset": "debug" },
    { "name": "debug-static", "configurePreset": "debug-static" }
  ]
}
